{
  "name": "typescript-express-v2",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc ",
    "start": "node dist/app.js",
    "dev": "nodemon --watch \"src/**\" --watch .env --ext \"ts,json,.env\" --ignore \"src/**/*.spec.ts\" --exec \"ts-node --project tsconfig.json src/app.ts\"",
    "prisma": "npx prisma generate",
    "db:drop": "npm run prisma && npx prisma migrate reset --force",
    "db:migrate": "npm run prisma && npx prisma migrate dev --name migrations",
    "db:fresh": "npm run db:drop && npm run db:migrate",
    "db:seed": "npx prisma db seed",
    "db:fresh:seed": "npm run db:fresh && npm run db:seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/lib-storage": "^3.971.0",
    "@aws-sdk/s3-request-presigner": "^3.888.0",
    "@elastic/elasticsearch": "^8.17.0",
    "@faker-js/faker": "^9.9.0",
    "@network-utils/arp-lookup": "^2.1.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@sentry/node": "^7.87.0",
    "argon2": "^0.30.3",
    "axios": "1.15.2",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.18.1",
    "mime-types": "^3.0.2",
    "moment": "^2.30.1",
    "morgan": "^1.10.1",
    "multer": "2.1.1",
    "nodemon": "^3.1.10",
    "pg": "^8.16.3",
    "redis": "^6.0.0",
    "serverless-http": "^4.0.0",
    "socket.io": "^4.8.1",
    "ts-node": "^10.9.1",
    "ts-proto": "^2.8.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/amqplib": "^0.10.7",
    "@types/argon2": "^0.14.1",
